# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
APP_NAME=Moni Finance Agent
APP_VERSION=1.0.0

# LLM provider: openai | gemini | google | local
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
OPENAI_API_KEY=
GEMINI_API_KEY=
LOCAL_MODEL_PATH=

# Security
AGENT_API_KEY=dev-key-change-me

# Rate limit and budget guard
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0
MAX_DAILY_REQUESTS=200
PRICE_PER_1K_TOKENS_USD=0.0006

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
